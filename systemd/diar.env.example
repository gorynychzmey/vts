# Diarization sidecar env file (template).
#
# Deploy to /opt/vts/config/diar.env on the host. Kept SEPARATE from vts.env so
# the pyannote sidecar never sees app secrets (VTS_OAUTH_*, etc.): this whole
# file is passed into the container via `--env-file` in vts-diarization.service,
# and is also read by that unit (EnvironmentFile) for the ${DIARIZATION_IMAGE}
# substitution, and sourced by deploy-after-diarization.yml. Keep it to
# DIARIZATION_IMAGE + DIAR_* only — anything added here lands inside the sidecar.

# The sidecar image reference. Released on its own diar-build-X.Y.Z tag,
# versioned independently of VTS — deploy-after-diarization.yml pulls exactly
# this reference, then restarts vts-diarization.service.
DIARIZATION_IMAGE=ghcr.io/OWNER/vts-diarization:latest

# Fills a speaker's breathing pauses shorter than this many seconds.
# Calibrated to 0.5 on a real 4-speaker meeting (halves segment fragmentation
# without merging distinct speakers).
DIAR_MIN_DURATION_OFF=0.5

# VBx acoustic scaling. The model ships 0.07, at which a short interjection
# nested inside a longer turn is smeared into that turn's speaker (task
# b07f7491: 0/4 marked interjections separated). 0.15 recovers most of them for
# the cost of a couple of extra speaker labels the resolve UI folds onto one
# person; 0.2 barely helps but jumps the speaker count. Unset -> model default.
DIAR_CLUSTERING_FA=0.15

# Other tunable VBx knobs (unset -> model defaults):
# DIAR_CLUSTERING_FB=0.8
# DIAR_CLUSTERING_THRESHOLD=0.6
